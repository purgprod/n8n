    {
      "id": "select",
      "name": "Selecionar Contato",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst staticData = $getWorkflowStaticData('global');\n\nconst today = new Date().toISOString().split('T')[0];\nif (!staticData.dailySent) staticData.dailySent = {};\n\n// Limpa dias antigos\nObject.keys(staticData.dailySent).forEach(day => {\n  if (day < today) delete staticData.dailySent[day];\n});\nif (!staticData.dailySent[today]) staticData.dailySent[today] = 0;\n\nconst DAILY_LIMIT = 100; // Aumentar conforme warmup: 100 → 200 → 300 → 500\n\n// Checa limite diário\nif (staticData.dailySent[today] >= DAILY_LIMIT) {\n  return [{ json: { hasContact: false, reason: 'daily_limit_reached', sent: staticData.dailySent[today] } }];\n}\n\n// Health index — últimas 20 mensagens (1 = entregue, 0 = falhou)\nconst health = staticData.healthIndex || [];\nif (health.length >= 20) {\n  const delivered = health.filter(h => h === 1).length;\n  const rate = delivered / health.length;\n  if (rate < 0.3) {\n    return [{ json: { hasContact: false, reason: 'low_health_index', rate: Math.round(rate * 100) + '%' } }];\n  }\n}\n\nconst eligibleStatuses = ['', 'Pendente'];\n\nlet selectedContact = null;\nfor (const item of items) {\n  const row = item.json;\n  const status = (row['Status'] || '').trim();\n  if (!eligibleStatuses.includes(status)) continue;\n\n  // Prioridade: D (Comercial) → E (Telefone) → F (Celular) → G (Aluno Celular)\n  const phoneFields = [\n    row['Titular - Comercial'],\n    row['Titular - Telefone'],\n    row['Titular - Celular'],\n    row['Aluno - Celular']\n  ];\n  const rawPhone = phoneFields.find(p => p && String(p).trim() !== '');\n  if (!rawPhone) continue;\n\n  let phone = String(rawPhone).replace(/\\D/g, '');\n  if (!phone.startsWith('55')) phone = '55' + phone;\n  if (phone.length < 12) continue; // número inválido\n\n  selectedContact = {\n    row_number: row['row_number'],\n    nome: String(row['Titular - Nome'] || '').trim(),\n    instituicao: String(row['INSTITUIÇÃO'] || '').trim(),\n    cidade: String(row['CIDADE'] || '').trim(),\n    phone,\n    rawPhone: String(rawPhone).trim()\n  };\n  break;\n}\n\nif (!selectedContact) {\n  return [{ json: { hasContact: false, reason: 'no_eligible_contacts' } }];\n}\n\nstaticData.dailySent[today]++;\n\nreturn [{ json: { hasContact: true, ...selectedContact } }];"
      }
    },
