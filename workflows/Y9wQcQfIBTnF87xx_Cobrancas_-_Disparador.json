        "jsCode": "const nome = $json.nome.split(' ')[0];\nconst instituicao = $json.instituicao;\nconst message = `Olá, ${nome}! Aqui é da secretaria da ${instituicao}. Tenho um recado sobre a situação da matrícula do aluno. Pode me responder? 😊`;\nreturn [{ json: { ...$json, message } }];"
      }
