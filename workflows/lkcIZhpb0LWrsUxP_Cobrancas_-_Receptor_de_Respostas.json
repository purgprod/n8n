    {
      "id": "buscar-linha",
      "name": "Buscar e Preparar Atualização",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const { phone, isOptOut } = $('Processar Evento').first().json;\nconst rows = $input.all();\n\n// Normaliza para comparar: remove não-dígitos e prefixo 55\nfunction normalizar(p) {\n  if (!p) return '';\n  let n = String(p).replace(/\\D/g, '');\n  if (n.startsWith('55') && n.length > 11) n = n.slice(2);\n  return n;\n}\n\nconst phoneNorm = normalizar(phone);\n\nconst match = rows.find(item => {\n  const row = item.json;\n  const status = (row['Status'] || '').trim();\n  if (!['Enviado'].includes(status)) return false;\n  const phones = [\n    row['Titular - Comercial'],\n    row['Titular - Telefone'],\n    row['Titular - Celular'],\n    row['Aluno - Celular']\n  ];\n  return phones.some(p => normalizar(p) === phoneNorm);\n});\n\nif (!match) return [{ json: { found: false, phone } }];\n\nconst newStatus = isOptOut ? 'Opt-out' : match.json['Status'];\nconst respondeu = isOptOut ? '' : 'Sim';\n\nreturn [{ json: {\n  found: true,\n  row_number: match.json['row_number'],\n  Status: newStatus,\n  Respondeu: respondeu\n}}];"
      }
    },
