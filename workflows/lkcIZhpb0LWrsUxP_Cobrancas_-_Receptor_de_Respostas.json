    {
      "id": "proc",
      "name": "Processar Evento",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        300
      ],
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst event = body.event || '';\nconst data = body.data || {};\nconst key = data.key || {};\n\n// Só processa mensagens recebidas (não enviadas por nós)\nif (event !== 'messages.upsert') return [{ json: { skip: true, event } }];\nif (key.fromMe === true) return [{ json: { skip: true, reason: 'fromMe' } }];\n\nconst remoteJid = key.remoteJid || '';\nlet phone = remoteJid.replace('@s.whatsapp.net', '').replace('@c.us', '');\n\nconst msgContent = data.message || {};\nconst text = (\n  msgContent.conversation ||\n  (msgContent.extendedTextMessage && msgContent.extendedTextMessage.text) ||\n  ''\n).toLowerCase().trim();\n\nconst optOutWords = ['não', 'nao', 'para', 'parar', 'sair', 'cancelar', 'remover', 'stop'];\nconst isOptOut = optOutWords.some(w => text === w || text.startsWith(w + ' '));\n\nreturn [{ json: { skip: false, phone, text, isOptOut } }];"
      }
    },
